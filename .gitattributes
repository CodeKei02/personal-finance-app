# Normalize line endings: store as LF in the repo, check out native on each OS.
* text=auto eol=lf

# Treat common binary assets as binary (no EOL normalization).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
